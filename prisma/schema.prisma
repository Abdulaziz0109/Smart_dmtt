generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  district_admin
  kindergarten_director
  staff
  parent
}

enum EnrollmentStatus {
  active
  paused
  cancelled
}

enum InvoiceStatus {
  unpaid
  paid
  cancelled
  overdue
}

enum PaymentStatus {
  succeeded
  failed
}

enum PaymentProvider {
  click
  payme
}

model District {
  id            String         @id @default(cuid())
  name          String
  kindergartens Kindergarten[]
  users         User[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Kindergarten {
  id                String         @id @default(cuid())
  districtId        String
  name              String
  address           String
  district          District       @relation(fields: [districtId], references: [id])
  users             User[]
  clubs             Club[]
  children          Child[]
  expenseLimit      ExpenseLimit?
  cardTransactions  CardTransaction[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model User {
  id             String     @id @default(cuid())
  districtId     String?
  kindergartenId String?
  fullName       String
  email          String     @unique
  passwordHash   String
  role           UserRole
  district       District?     @relation(fields: [districtId], references: [id])
  kindergarten   Kindergarten? @relation(fields: [kindergartenId], references: [id])
  parentProfile  ParentProfile?
  auditLogs      AuditLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  user      User     @relation(fields: [userId], references: [id])
  children  Child[]
  invoices  Invoice[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Child {
  id             String       @id @default(cuid())
  fullName       String
  birthDate      DateTime
  groupName      String?
  kindergartenId String
  parentId       String
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id])
  parent         ParentProfile @relation(fields: [parentId], references: [id])
  enrollments    Enrollment[]
  invoices       Invoice[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Club {
  id             String       @id @default(cuid())
  kindergartenId String
  name           String
  description    String
  monthlyPrice   Decimal      @db.Decimal(12, 2)
  teacherName    String
  capacity       Int
  schedule       String
  isActive       Boolean      @default(true)
  kindergarten   Kindergarten @relation(fields: [kindergartenId], references: [id])
  enrollments    Enrollment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Enrollment {
  id        String           @id @default(cuid())
  childId   String
  clubId    String
  status    EnrollmentStatus @default(active)
  startDate DateTime
  endDate   DateTime?
  child     Child            @relation(fields: [childId], references: [id])
  club      Club             @relation(fields: [clubId], references: [id])
  invoices  Invoice[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([childId, clubId])
}

model Invoice {
  id           String       @id @default(cuid())
  parentId     String
  childId      String
  enrollmentId String
  month        String
  amount       Decimal      @db.Decimal(12, 2)
  status       InvoiceStatus @default(unpaid)
  dueDate      DateTime
  parent       ParentProfile @relation(fields: [parentId], references: [id])
  child        Child        @relation(fields: [childId], references: [id])
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  payment      Payment?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([enrollmentId, month])
}

model Payment {
  id                   String         @id @default(cuid())
  invoiceId            String         @unique
  amount               Decimal        @db.Decimal(12, 2)
  provider             PaymentProvider
  transactionReference String
  paidAt               DateTime
  status               PaymentStatus  @default(succeeded)
  invoice              Invoice        @relation(fields: [invoiceId], references: [id])
  createdAt            DateTime       @default(now())
}

model ExpenseLimit {
  id                     String       @id @default(cuid())
  kindergartenId         String       @unique
  dailyLimit             Decimal      @db.Decimal(12, 2)
  singleTransactionLimit Decimal      @db.Decimal(12, 2)
  monthlyLimit           Decimal      @db.Decimal(12, 2)
  kindergarten           Kindergarten @relation(fields: [kindergartenId], references: [id])
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model AllowedMerchantCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CardTransaction {
  id                String   @id @default(cuid())
  kindergartenId    String
  cardName          String?
  cardLast4         String?
  merchantName      String
  merchantCategory  String
  amount            Decimal  @db.Decimal(12, 2)
  transactionTime   DateTime
  currency          String
  rawReference      String
  status            String
  suspiciousFlag    Boolean  @default(false)
  suspiciousReason  String?
  kindergarten      Kindergarten @relation(fields: [kindergartenId], references: [id])
  createdAt         DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}
